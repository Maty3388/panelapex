<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="56dp"
    android:background="@color/surface" android:orientation="horizontal"
    android:gravity="center_vertical" android:paddingHorizontal="12dp"
    android:layout_marginBottom="1dp">

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvTitle"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" android:textSize="14sp"
            android:textStyle="bold" android:maxLines="1" android:ellipsize="end"/>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="2dp">
            <TextView android:id="@+id/tvCategory"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/primary" android:textSize="11sp"
                android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/tvYear"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/text_secondary" android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

    <TextView android:id="@+id/btnEdit"
        android:layout_width="36dp" android:layout_height="32dp"
        android:text="✏️" android:gravity="center" android:textSize="14sp"
        android:background="@color/surface2" android:layout_marginEnd="4dp"
        android:clickable="true"/>
    <TextView android:id="@+id/btnDelete"
        android:layout_width="36dp" android:layout_height="32dp"
        android:text="🗑️" android:gravity="center" android:textSize="14sp"
        android:background="@color/error" android:clickable="true"/>
</LinearLayout>
