<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background" android:orientation="vertical">

    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="@color/surface" android:gravity="center_vertical"
        android:paddingHorizontal="16dp" android:orientation="horizontal">
        <TextView android:id="@+id/btnBack"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="←" android:textColor="@color/primary" android:textSize="20sp"
            android:padding="4dp" android:clickable="true" android:layout_marginEnd="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="💰 Créditos" android:textColor="@color/text_primary"
            android:textSize="17sp" android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <TextView android:id="@+id/tvMyCredits"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/primary" android:textSize="22sp"
            android:textStyle="bold" android:layout_marginBottom="4dp"/>
        <TextView android:id="@+id/tvMyRole"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_secondary" android:textSize="13sp"
            android:layout_marginBottom="24dp"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/border" android:layout_marginBottom="24dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Asignar créditos" android:textColor="@color/text_primary"
            android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="16dp"/>

        <EditText android:id="@+id/etEmail"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:hint="Email del revendedor" android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" android:background="@color/surface2"
            android:paddingHorizontal="16dp" android:inputType="textEmailAddress"
            android:layout_marginBottom="8dp"/>

        <EditText android:id="@+id/etAmount"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:hint="Cantidad de créditos" android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" android:background="@color/surface2"
            android:paddingHorizontal="16dp" android:inputType="number"
            android:layout_marginBottom="16dp"/>

        <Button android:id="@+id/btnAssign"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="💰 ASIGNAR CRÉDITOS" android:textColor="@color/background"
            android:backgroundTint="@color/primary" android:textStyle="bold"/>
    </LinearLayout>
</LinearLayout>
